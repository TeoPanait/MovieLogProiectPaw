@{
    ViewData["Title"] = "adauga film";
}

<div class="container mt-4">
    <h2>adauga un film nou in catalog</h2>
    <hr />
    <div class="row">
        <div class="col-md-6">
            <!-- Am adaugat tag-ul form ca sa activeze validarea automata a browserului -->
            <form id="createForm">
                <div class="mb-3">
                    <label class="form-label">titlu film</label>
                    <!-- 'required' si 'minlength' obliga browserul sa verifice continutul -->
                    <input type="text" id="title" class="form-control" placeholder="scrie titlul..." required minlength="3" />
                </div>

                <div class="mb-3">
                    <label class="form-label">descriere</label>
                    <!-- 'required' obliga browserul sa verifice daca textul e gol -->
                    <textarea id="description" class="form-control" rows="3" placeholder="scrie o scurta descriere..." required></textarea>
                </div>

                <button type="button" id="btnSave" class="btn btn-primary">salveaza in baza de date</button>
                <a href="/Home/Index" class="btn btn-secondary ms-2">inapoi la lista</a>
            </form>

            <div id="mesaj" class="mt-3"></div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        document.getElementById('btnSave').addEventListener('click', function () {
            const form = document.getElementById('createForm');

            // Aceasta este diferenta majora: verificam daca formularul e valid in browser
            if (!form.checkValidity()) {
                alert("Te rugam sa completezi corect toate campurile!");
                return; // Oprim executia aici, nu facem fetch
            }

            // luam ce a scris adminul in casute
            const movieData = {
                title: document.getElementById('title').value,
                description: document.getElementById('description').value
            };

            // trimitem datele la api ul tau cu metoda post
            fetch('/api/movies', {
                method: 'POST',
                headers: {
                    'Content-Type': 'application/json'
                },
                body: JSON.stringify(movieData)
            })
            .then(response => {
                if (response.ok) {
                    document.getElementById('mesaj').innerHTML = '<span class="text-success fw-bold">filmul a fost adaugat cu succes!</span>';
                    // curatam casutele dupa succes
                    document.getElementById('title').value = '';
                    document.getElementById('description').value = '';
                } else {
                    document.getElementById('mesaj').innerHTML = '<span class="text-danger fw-bold">eroare la adaugare.</span>';
                }
            })
            .catch(error => {
                console.error('eroare la fetch:', error);
            });
        });
    </script>
}