@using System.Security.Claims
@{
    ViewData["Title"] = "Watchlist-ul Meu";
    // luam user id sa stim a cui e lsita
    var currentUserId = User.Identity != null && User.Identity.IsAuthenticated
                        ? User.FindFirst(ClaimTypes.NameIdentifier)?.Value
                        : "";
}

<div class="container mt-4">
    <h2>Filmele salvate de mine</h2>
    <hr />
    <div class="row" id="watchlist-container">
        <div class="col-12">
            <p class="text-muted">Se incarca lista ta...</p>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        const currentUserId = "@currentUserId";

        document.addEventListener('DOMContentLoaded', function () {
            // cerem de la server toate watchlist urile
            fetch('/api/watchlists')
                .then(response => response.json())
                .then(data => {
                    const container = document.getElementById('watchlist-container');

					// cautram lista care apartine userului curent
                    const myWatchlist = data.find(w => w.userId === currentUserId);

                    if (!myWatchlist || !myWatchlist.movieTitles || myWatchlist.movieTitles.length === 0) {
                        container.innerHTML = '<p class="text-warning">Nu ai adaugat niciun film in watchlist inca.</p>';
                        return;
                    }

                    let htmlList = '<ul class="list-group col-md-6 shadow-sm">';

                    myWatchlist.movieTitles.forEach(title => {
                        htmlList += `
                            <li class="list-group-item d-flex justify-content-between align-items-center">
                                <strong>${title}</strong>
                                <span class="badge bg-success rounded-pill">Salvat</span>
                            </li>`;
                    });

                    htmlList += '</ul>';
                    container.innerHTML = htmlList;
                })
                .catch(error => {
                    console.error('Eroare API:', error);
                    document.getElementById('watchlist-container').innerHTML = '<p class="text-danger">A aparut o eroare la incarcarea datelor.</p>';
                });
        });
    </script>
}